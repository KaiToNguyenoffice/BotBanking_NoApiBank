# Sao chép thành .env và điền giá trị thật:
#   copy .env.example .env

# === Bot (bắt buộc) ===
BOT_TOKEN=

# Admin: Telegram user ID, nhiều ID cách nhau dấu phẩy
ADMIN_IDS=

# === Database (tuỳ chọn) ===
# Mặc định trong code: sqlite+aiosqlite:///bot_shop.db
# DATABASE_URL=sqlite+aiosqlite:///bot_shop.db

# === Ngân hàng / VietQR (nạp tiền) ===
BANK_BIN=
BANK_ACCOUNT_NUMBER=
BANK_ACCOUNT_NAME=
BANK_NAME=
MIN_DEPOSIT=10000

# Dự phòng — hiện chưa dùng trong code
# CASSO_API_KEY=

# === Webhook nạp tự động (MacroDroid / HTTP POST) ===
WEBHOOK_PORT=8443
WEBHOOK_SECRET=change_this_to_a_long_random_string
WEBHOOK_REQUIRE_SECRET=true
WEBHOOK_REQUIRE_PS_LINE=false
WEBHOOK_ALLOW_REF_ONLY=false
